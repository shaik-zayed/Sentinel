# =============================================================================
# Sentinel – Environment variables template
#
# Usage:
#   cp .env.example .env
#   # Edit .env and fill in every value
#   docker compose up --build
#
# Rules:
#   • .env is in .gitignore — NEVER commit it to source control.
#   • Every variable marked REQUIRED must be set. docker compose will fail
#     fast with a clear error if any REQUIRED variable is missing.
#   • Generate secrets with: openssl rand -base64 32
#   • Rotate secrets regularly. Do not reuse them across environments.
# =============================================================================

# -----------------------------------------------------------------------------
# JWT
# REQUIRED. Used by api-gateway (validation) and auth-service (signing).
# Must be Base64-encoded and at least 256 bits (32 bytes) for HMAC-SHA256.
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# -----------------------------------------------------------------------------
# MySQL
# REQUIRED. Set before first docker compose up — values are written into the
# MySQL data volume and cannot be changed without destroying the volume.
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=root
DB_PASSWORD=mysql

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object store for scan reports)
# REQUIRED.
# Generate: openssl rand -hex 16   (access key)
#           openssl rand -base64 32 (secret key)
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=sentinel
MINIO_SECRET_KEY=sentinel123
MINIO_BUCKET=sentinel-reports

# -----------------------------------------------------------------------------
# Kafka
# REQUIRED. A stable, unique identifier for the Kafka cluster.
# Generate: docker run --rm confluentinc/cp-kafka:7.7.1 kafka-storage random-uuid
# This value is baked into the Kafka data volume on first boot and should never
# change for the lifetime of that volume.
# -----------------------------------------------------------------------------
KAFKA_CLUSTER_ID=MkQrZGJiNTcwYTI4NDQ2ZTk5

# -----------------------------------------------------------------------------
# CORS (optional — defaults cover the standard dev ports)
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:7777

# -----------------------------------------------------------------------------
# Email (optional — defaults use the built-in smtp4dev dev mail sink)
# For production replace with real SMTP credentials (SES, Mailgun, etc.)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_VERIFICATION_URL=https://app.yourdomain.com/verify-email
# EMAIL_PASSWORD_RESET_URL=https://app.yourdomain.com/reset-password