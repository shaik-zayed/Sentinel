flowchart TD

subgraph OuterBox[" "]
direction TB
style OuterBox fill:#ffffff,stroke:#ffffff,stroke-width:0px

subgraph Client_Layer["🌐 Client"]
Client["Browser / REST Client"]
end

subgraph Gateway_Layer["🚪 API Gateway :7777"]
Gateway["JWT validation, routing, tracing"]
end

subgraph CoreAndStorage[" "]
direction LR

subgraph Service_Layer["🧠 Core Services"]
direction LR
Auth["🔐 Auth Service :8083<br/>Registration, Login, JWT, Blacklist"]
Scan["📡 Scan Service :8081<br/>Request intake, result persistence<br/>CVE enrichment orchestration"]
Report["📄 Report Service :8085<br/>PDF / HTML / JSON / DOCX generation"]
Nmap["🐳 Nmap Service :8082<br/>Docker orchestration"]
end

subgraph Storage_Layer["💾 Storage"]
direction TB
MySQL[("MySQL :3306")]
Kafka[("Kafka :9092")]
MinIO[("MinIO :9000")]
end
end

subgraph Discovery_Layer["🔍 Service Discovery"]
Eureka["Eureka Server :8761"]
end

subgraph External_Layer["🌍 External APIs"]
NVD["NVD API<br/>nvd.nist.gov<br/>CVE lookup"]
end

Docker["Docker daemon<br/>ephemeral nmap containers"]

Client --> Gateway

Gateway --> Auth
Gateway --> Scan
Gateway --> Report

Gateway -.->|discover| Eureka
Auth -.->|register| Eureka
Scan -.->|register| Eureka
Report -.->|register| Eureka
Nmap -.->|register| Eureka

Scan -->|publish scan job| Kafka
Kafka -->|consume scan job| Nmap
Nmap -->|publish result| Kafka
Kafka -->|consume result| Scan

Scan -->|async enrichment| NVD
NVD -->|CVE findings| Scan

Report -->|fetch result + findings| Scan

Auth --> MySQL
Scan --> MySQL
Report --> MinIO

Nmap -.->|spawns| Docker
end

