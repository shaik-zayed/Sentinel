flowchart TD
subgraph OuterBox[" "]
direction TB
style OuterBox fill:#f6f8fa,stroke:#f6f8fa,stroke-width:0px

subgraph Client_Layer["🌐 Client"]
Client["Browser / REST Client"]
end

subgraph Gateway_Layer["🚪 API Gateway :7777"]
Gateway["JWT validation, routing, tracing"]
end

subgraph Service_Layer["🧠 Core Services"]
Auth["🔐 Auth Service :8083<br/>Registration, Login, JWT, Blacklist"]
Scan["📡 Scan Service :8081<br/>Request intake, result persistence"]
Report["📄 Report Service :8085<br/>Generation, MinIO storage"]
Nmap["🐳 Nmap Service :8082<br/>Docker orchestration"]
end

subgraph Discovery_Layer["🔍 Service Discovery"]
Eureka["Eureka Server :8761"]
end

subgraph Storage_Layer["💾 Storage"]
MySQL[("MySQL :3306")]
MinIO[("MinIO :9000")]
Kafka[("Kafka :9092")]
end

Client --> Gateway
Gateway --> Auth
Gateway --> Scan
Gateway --> Report

Gateway -.->|discover| Eureka
Auth -.->|register| Eureka
Scan -.->|register| Eureka
Report -.->|register| Eureka
Nmap -.->|register| Eureka

Scan -->|publish| Kafka
Kafka -->|consume| Nmap
Nmap -->|publish result| Kafka
Kafka -->|consume| Scan

Scan --> MySQL
Auth --> MySQL
Report --> MinIO

Nmap -.->|spawns| Docker["Docker daemon<br/>ephemeral nmap containers"]
end

