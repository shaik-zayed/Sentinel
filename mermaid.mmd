sequenceDiagram
    autonumber
    participant User
    participant Gateway as API Gateway
    participant Auth as Auth Service
    participant Scan as Scan Service
    participant Kafka
    participant Nmap as Nmap Service
    participant Result as Result Service<br/>(NEW - SEPARATE)
    participant Report as Report Service
    participant DB as MySQL

    rect rgb(200, 230, 255)
        Note over User,Auth: PHASE 1: AUTHENTICATION
        User->>Gateway: POST /auth/login
        Gateway->>Auth: Forward credentials
        Auth->>Auth: Validate password
        Auth->>Auth: Generate JWT tokens
        Auth-->>Gateway: {accessToken, refreshToken}
        Gateway-->>User: Return tokens
    end

    rect rgb(255, 230, 200)
        Note over User,DB: PHASE 2: SCAN SUBMISSION
        User->>Gateway: POST /api/v1/scans<br/>Authorization: Bearer {token}
        Gateway->>Gateway: Validate JWT
        Gateway->>Scan: Forward with userId
        Scan->>DB: INSERT scan_request<br/>INSERT scan_item (status=QUEUED)
        DB-->>Scan: scanId
        Scan->>Kafka: Produce scan_cmd
        Scan-->>Gateway: 202 Accepted {scanId, status: QUEUED}
        Gateway-->>User: {scanId, status: QUEUED}
    end

    rect rgb(230, 255, 230)
        Note over Kafka,DB: PHASE 3: ASYNC SCAN EXECUTION
        Kafka->>Nmap: Consume scan_cmd
        Nmap->>DB: UPDATE scan_item (status=IN_PROGRESS)
        Nmap->>Nmap: Run Docker container
        Nmap->>Nmap: Capture XML output
        Nmap->>Kafka: Produce scan_result (XML + metadata)
        Nmap->>DB: UPDATE scan_item (status=COMPLETED)

        Note over Result: SEPARATE SERVICE!
        Kafka->>Result: Consume scan_result
        Result->>Result: Parse XML
        Result->>DB: INSERT scan_results<br/>INSERT ports
        Result->>DB: UPDATE scan_item (result_available=true)
    end

    rect rgb(255, 255, 200)
        Note over User,DB: PHASE 4: STATUS POLLING (USER INITIATED)
        User->>Gateway: GET /api/v1/scans/{scanId}/status
        Gateway->>Scan: Forward
        Scan->>DB: SELECT scan_item WHERE scanId
        DB-->>Scan: {status, result_available}
        Scan-->>User: {status: COMPLETED, result_available: true}
    end

    rect rgb(255, 200, 255)
        Note over User,Report: PHASE 5: REPORT GENERATION (SYNCHRONOUS!)
        User->>Gateway: GET /api/v1/reports/{scanId}?format=pdf
        Gateway->>Gateway: Validate JWT
        Gateway->>Report: Forward with userId
        Report->>DB: SELECT scan_results WHERE scanId AND userId
        DB-->>Report: XML + parsed data
        Report->>Report: Generate PDF
        Report-->>Gateway: PDF bytes
        Gateway-->>User: Download PDF (immediate response)
    end
